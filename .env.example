# ========================================
# GYMBUDDY - CONFIGURAZIONE DI PRODUZIONE
# ========================================
# Riempi i campi con le credenziali reali
# e rinomina questo file in ".env"
# ========================================

# --- DATABASE POSTGRESQL ---
POSTGRES_USER=testuser
POSTGRES_PASSWORD=testpassword
POSTGRES_DB=gymbuddy

# --- SICUREZZA API E TOKEN ---
# Genera una SECRET_KEY sicura: `openssl rand -hex 32`
SECRET_KEY=09d25e094faa6ca2556c818166b7a9563b93f7099f6f0f4caa6cf63b88e8d3e7
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
# Password che avrà l'account Admin appena generato al primo avvio
ADMIN_DEFAULT_PASSWORD=CHANGE_ME_NOW
DEBUG=false

# --- CORS E RETE (NGINX PROXY) ---
# Se deployi su un server, scrivi qui l'IP del Server o localhost se locale
VPS_IP=123.456.789.100
# Sostituisci questo con il nome del tuo dominio (se lo possiedi) altrimenti ignora.
DOMAIN_NAME=gymbuddy.com
